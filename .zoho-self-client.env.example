# Zoho self-client OAuth token cache — LOCAL ONLY.
# The real .zoho-self-client.env is gitignored; never commit real values.
# Obtain tokens via the Zoho self-client flow. ZOHO_ACCESS_TOKEN is short-lived (~1h)
# and refreshed out-of-band; rotate immediately if a real value is ever exposed.
ZOHO_ACCESS_TOKEN=replace-with-access-token
ZOHO_API_DOMAIN=https://www.zohoapis.eu
ZOHO_TOKEN_EXPIRES_IN=3600
ZOHO_TOKEN_OBTAINED_AT=0
